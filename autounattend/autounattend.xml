<?xml version="1.0" encoding="utf-8"?>
<!--
    autounattend.xml — Windows 10 Pro 22H2 unattended answer file
    Place at the root of the bootable ISO or USB drive before booting.

    BEFORE DEPLOYING:
      1. Replace CHANGEME in <Password> and <AutoLogon> with your intended local admin password.
      2. Adjust <TimeZone> if needed (default: Eastern Standard Time).
      3. Validate in Windows SIM against the install.wim catalog.
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend">

  <!-- ============================================================
       windowsPE — disk layout, locale, image selection
       ============================================================ -->
  <settings pass="windowsPE">

    <component
      name="Microsoft-Windows-International-Core-WinPE"
      processorArchitecture="amd64"
      publicKeyToken="31bf3856ad364e35"
      language="neutral"
      versionScope="nonSxS"
      xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component
      name="Microsoft-Windows-Setup"
      processorArchitecture="amd64"
      publicKeyToken="31bf3856ad364e35"
      language="neutral"
      versionScope="nonSxS"
      xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

      <!-- UEFI / GPT disk layout for Disk 0 -->
      <DiskConfiguration>
        <Disk wcm:action="add">
          <DiskID>0</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          <CreatePartitions>
            <!-- Partition 1: EFI System Partition (300 MB) -->
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Type>EFI</Type>
              <Size>300</Size>
            </CreatePartition>
            <!-- Partition 2: Microsoft Reserved Partition (16 MB) -->
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Type>MSR</Type>
              <Size>16</Size>
            </CreatePartition>
            <!-- Partition 3: Windows OS — remainder of disk -->
            <CreatePartition wcm:action="add">
              <Order>3</Order>
              <Type>Primary</Type>
              <Extend>true</Extend>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Label>System</Label>
              <Format>FAT32</Format>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>3</PartitionID>
              <Label>Windows</Label>
              <Format>NTFS</Format>
              <Letter>C</Letter>
            </ModifyPartition>
          </ModifyPartitions>
        </Disk>
      </DiskConfiguration>

      <ImageInstall>
        <OSImage>
          <InstallTo>
            <DiskID>0</DiskID>
            <PartitionID>3</PartitionID>
          </InstallTo>
          <WillShowUI>OnError</WillShowUI>
        </OSImage>
      </ImageInstall>

      <UserData>
        <AcceptEula>true</AcceptEula>
        <ProductKey>
          <WillShowUI>Never</WillShowUI>
        </ProductKey>
      </UserData>

    </component>
  </settings>

  <!-- ============================================================
       specialize — computer name, time zone (runs pre-OOBE)
       ============================================================ -->
  <settings pass="specialize">

    <component
      name="Microsoft-Windows-Shell-Setup"
      processorArchitecture="amd64"
      publicKeyToken="31bf3856ad364e35"
      language="neutral"
      versionScope="nonSxS"
      xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <!-- * = auto-generate a unique computer name -->
      <ComputerName>*</ComputerName>
      <TimeZone>Eastern Standard Time</TimeZone>
    </component>

  </settings>

  <!-- ============================================================
       oobeSystem — skip OOBE, create local admin, FirstLogonCommands
       ============================================================ -->
  <settings pass="oobeSystem">

    <component
      name="Microsoft-Windows-Shell-Setup"
      processorArchitecture="amd64"
      publicKeyToken="31bf3856ad364e35"
      language="neutral"
      versionScope="nonSxS"
      xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>false</HideLocalAccountScreen>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <NetworkLocation>Work</NetworkLocation>
        <!-- 3 = do not set up automatic updates (manage via policy) -->
        <ProtectYourPC>3</ProtectYourPC>
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>

      <!-- Local admin account — CHANGE BEFORE DEPLOY -->
      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Description>Local administrator</Description>
            <DisplayName>LocalAdmin</DisplayName>
            <Group>Administrators</Group>
            <Name>LocalAdmin</Name>
            <Password>
              <Value>CHANGEME</Value>
              <PlainText>true</PlainText>
            </Password>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <!-- Auto-logon once to trigger FirstLogonCommands — CHANGE BEFORE DEPLOY -->
      <AutoLogon>
        <Enabled>true</Enabled>
        <LogonCount>1</LogonCount>
        <Username>LocalAdmin</Username>
        <Password>
          <Value>CHANGEME</Value>
          <PlainText>true</PlainText>
        </Password>
      </AutoLogon>

      <!--
          FirstLogonCommands — runs on first logon as LocalAdmin (Administrators group).

          Order 1: Install KB5078885 (2026-03 Cumulative Update, 19045.5440 -> 19045.7058)
                   Source: C:\Updates\ — staged into the image by Invoke-CleanupAndUnmount.ps1
                   wusa.exe /quiet is synchronous in this context; /norestart defers reboot.
                   Log written to C:\Windows\Logs\Setup\KB5078885-install.log

          Order 2: Restart 30 seconds after wusa completes to finalize the update.
      -->
      <FirstLogonCommands>
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <CommandLine>wusa.exe "C:\Updates\windows10.0-kb5078885-x64_8013483b567f16e057931c30725c6c8723007a31.msu" /quiet /norestart /log:"C:\Windows\Logs\Setup\KB5078885-install.log"</CommandLine>
          <Description>Install KB5078885 - 2026-03 Cumulative Update for Windows 10 22H2</Description>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <CommandLine>shutdown.exe /r /t 30 /c "Completing KB5078885 installation"</CommandLine>
          <Description>Restart to complete update installation</Description>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>
      </FirstLogonCommands>

    </component>
  </settings>

</unattend>
